const mongoose = require("mongoose");

const paymentSchema = new mongoose.Schema(
  {
    tenantId: { type: mongoose.Schema.Types.ObjectId, ref: "Tenant", required: true },
    invoiceId: { type: mongoose.Schema.Types.ObjectId, ref: "Invoice", required: true },
    associateId: { type: mongoose.Schema.Types.ObjectId, ref: "Associate", required: true },
    gateway: { type: String, enum: ["manual", "mercadopago", "cora"], default: "manual" },
    gatewayPaymentId: { type: String, trim: true },
    amountPaid: { type: Number, required: true },
    paidAt: { type: Date, default: Date.now },
    receiptPdfUrl: { type: String, trim: true },
    rawPayload: { type: Object, default: {} }
  },
  { timestamps: true }
);

paymentSchema.index({ tenantId: 1, paidAt: -1 });
paymentSchema.index({ tenantId: 1, invoiceId: 1 });
paymentSchema.index(
  { gateway: 1, gatewayPaymentId: 1 },
  { unique: true, sparse: true }
);

module.exports = mongoose.model("Payment", paymentSchema);
